# backend/.env.example
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env — only this .env.example file goes to Git.
# ─────────────────────────────────────────────────────────────────

# ── DATABASE (Sujit P) ────────────────────────────────────────────
DATABASE_URL=postgresql://eldermind_user:YOUR_PASSWORD@localhost:5432/eldermind

# ── JWT AUTH (Sujit P) ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_random_32_character_string_here

# ── OPENAI (Tanisha) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here

# ── SARVAM AI (Sukirthan) ─────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here

# ── TWILIO SMS (Shivani) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── SCAM ALERTS (Sudharsan) ──────────────────────────────────────
FAMILY_ALERT_NUMBER=+91XXXXXXXXXX
